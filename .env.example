# Surface IQ — environment template
# Copy to .env and fill in. Never commit .env.

# --- Phase 1 (database) ---
# Local Postgres example: postgresql://surfaceiq:surfaceiq@localhost:5432/surfaceiq
# Supabase / Neon / Railway: paste their pooled or direct URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# --- Phase 0 (password gate, production only) ---
# Any string. The middleware compares against the Authorization header
# (Basic auth) or the surface_iq_session cookie. Skip in dev.
SURFACE_IQ_PASSWORD=

# --- Phase 3 (LLM categorization fallback, optional) ---
# Without this, the keyword classifier handles everything (~80% accuracy).
# With this, posts below confidence 0.7 are reclassified by gpt-4o-mini.
OPENAI_API_KEY=

# --- Phase 4 (scrape pipeline) ---
# Required to run live scrapes. Without it, /api/scrape returns 503.
SPIDER_API_KEY=

# Optional discovery/enrichment provider for cited public web research.
PARALLEL_API_KEY=

# Optional official-platform providers. Without them, acquisition falls back to
# public feeds, Spider/Parallel discovery, or manual import as appropriate.
X_API_KEY=
GITHUB_TOKEN=
LINKEDIN_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=

# Bearer secret the Vercel cron handlers expect. Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional — when set, YouTube parser uses the official Data API v3 instead of Spider.
YOUTUBE_API_KEY=

# --- Phase 6b (server-side player card / PDF rendering, optional) ---
# Reserved for object storage of generated artifacts (R2 or S3).
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=

# --- Phase 8 (Clerk auth upgrade, optional) ---
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
