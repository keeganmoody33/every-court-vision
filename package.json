{
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"postinstall": "prisma generate",
		"prisma:validate": "prisma validate",
		"prisma:generate": "prisma generate",
		"db:push": "psql \"$DATABASE_URL\" -f db/schema.sql",
		"db:seed": "tsx prisma/seed.ts",
		"db:studio": "prisma studio",
		"db:migrate": "for f in db/migrations/*/migration.sql db/migrations/*.sql; do [ -f \"$f\" ] && (echo \"-- $f\" >&2; psql \"$DATABASE_URL\" -f \"$f\"); done",
		"db:backfill": "tsx scripts/backfill-acquisition.ts",
		"backfill:x": "NODE_OPTIONS=--conditions=react-server tsx scripts/backfill-x.ts",
		"ingest": "NODE_OPTIONS=--conditions=react-server tsx scripts/ingest-all.ts",
		"dev:inngest": "node_modules/inngest-cli/bin/inngest dev",
		"dev:all": "concurrently -n next,inngest \"pnpm dev\" \"pnpm dev:inngest\"",
		"seed:employees": "tsx scripts/seed-employees.ts",
		"discover:surfaces": "tsx scripts/discover-surfaces.ts",
		"sync:sheets": "tsx scripts/sync-from-sheets.ts"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.1.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@tanstack/react-table": "^8.21.3",
		"@types/pg": "^8.20.0",
		"@vercel/analytics": "^2.0.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"d3": "^7.9.0",
		"framer-motion": "^12.38.0",
		"googleapis": "^164.1.0",
		"inngest": "^4.2.5",
		"lucide-react": "^1.11.0",
		"next": "^16.2.4",
		"openai": "^6.34.0",
		"pg": "^8.20.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"recharts": "^3.8.1",
		"server-only": "^0.0.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@tailwindcss/forms": "^0.5.11",
		"@types/d3": "^7.4.3",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"autoprefixer": "^10.5.0",
		"concurrently": "^9.2.1",
		"dotenv": "^17.4.2",
		"eslint": "^9.39.4",
		"eslint-config-next": "^16.2.4",
		"eslint-plugin-surface-iq": "file:./eslint-plugin-surface-iq",
		"inngest-cli": "^1.18.0",
		"postcss": "^8.5.12",
		"prettier": "^3.8.3",
		"prisma": "^7.8.0",
		"tailwindcss": "3.4.17",
		"tsx": "^4.19.2",
		"typescript": "^5.9.3"
	},
	"pnpm": {
		"overrides": {
			"postcss": ">=8.5.10",
			"@hono/node-server": ">=1.19.13"
		},
		"onlyBuiltDependencies": [
			"@prisma/engines",
			"esbuild",
			"inngest-cli",
			"prisma",
			"protobufjs",
			"sharp",
			"unrs-resolver"
		]
	}
}
