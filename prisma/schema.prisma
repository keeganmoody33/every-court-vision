generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Platform {
  X
  LINKEDIN
  GITHUB
  INSTAGRAM
  NEWSLETTER
  YOUTUBE
  PODCAST
  LAUNCHES
  TEAMMATE_AMPLIFICATION
  EXTERNAL_AMPLIFICATION
  PRODUCT_HUNT
  PERSONAL_SITE
  TIKTOK
  WEBSITE
  SUBSTACK
  APP_STORE
  REFERRAL
  CONSULTING
}

enum MetricConfidence {
  DIRECT
  ESTIMATED
  MODELED
  HYPOTHESIS
  NEEDS_INTERNAL_ANALYTICS
}

enum DataReadiness {
  PUBLIC_ONLY
  MANUAL_IMPORT
  LIVE
}

enum SourceReadiness {
  READY
  MANUAL_IMPORT
  NEEDS_OAUTH
  FUTURE
}

enum AcquisitionProvider {
  X_API
  LINKEDIN_API
  GITHUB_API
  YOUTUBE_API
  RSS
  SPIDER
  PARALLEL
  MANUAL
  INSTAGRAM_GRAPH
}

enum AcquisitionJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
  DISABLED
}

enum IntentClass {
  THREE_POINT
  MID_RANGE
  PAINT
  FREE_THROW
  PASS
}

enum ShotOutcome {
  MADE
  MISSED
  TURNOVER
}

model Company {
  id                     String     @id @default(cuid())
  name                   String
  domain                 String
  website                String
  slug                   String?    @unique
  description            String?
  youtubeSubscribers     Int?
  youtubeViews           Int?
  youtubeVideos          Int?
  newsletterSubscribers  Int?
  xFollowers             Int?
  linkedinFollowers      Int?
  githubRepos            Int?
  productHuntProducts    Int?
  podcastEpisodes        Int?
  teamSize               Int?
  publicFacingCount      Int?
  employees              Employee[]
  surfaces               Surface[]
  reports                Report[]
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

model Employee {
  id                String          @id @default(cuid())
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  name              String
  role              String
  archetype         String?
  dataReadiness     DataReadiness   @default(PUBLIC_ONLY)
  primarySurface    Platform
  secondarySurface  Platform
  signatureMove     String
  opportunity       String
  bestShot          String
  bestAssist        String
  surfacePresence   Float           @default(0)
  surfaceIQ         Float           @default(0)
  trustGravity      Float           @default(0)
  socialTS          Float           @default(0)
  shotDistribution  Json            @default("{}")
  xFollowers        Int?
  isPublicFacing    Boolean         @default(false)
  recommendedPlayId String?
  accounts          SocialAccount[]
  surfaces          Surface[]
  metrics           Metric[]
  posts             Post[]
  rippleEvents      RippleEvent[]
  experiments       Experiment[]
  discoveredSurfaces DiscoveredSurface[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model SocialAccount {
  id           String           @id @default(cuid())
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id])
  platform     Platform
  handle       String
  followers    Int
  confidence   MetricConfidence
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Surface {
  id               String           @id @default(cuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id])
  employeeId       String?
  employee         Employee?        @relation(fields: [employeeId], references: [id])
  platform         Platform
  handle           String
  url              String?
  present          Boolean          @default(true)
  status           String           @default("VERIFIED")
  followers        Int              @default(0)
  confidence       MetricConfidence @default(ESTIMATED)
  lastScrapedAt    DateTime?
  attributionValue String?
  opportunity      String?
  posts            Post[]
  metrics          Metric[]
  acquisitionJobs  AcquisitionJob[]
  rawActivities    RawActivity[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([companyId, platform])
  @@index([employeeId, platform])
}

model Post {
  id                 String          @id @default(cuid())
  employeeId         String
  employee           Employee        @relation(fields: [employeeId], references: [id])
  surfaceId          String?
  surface            Surface?        @relation(fields: [surfaceId], references: [id])
  text               String
  platform           Platform
  contentType        String
  archetype          String
  campaign           String
  ctaType            String
  brandTouch         String
  product            String
  launchWindow       Boolean         @default(false)
  publishedAt        DateTime
  x                  Float           @default(50)
  y                  Float           @default(47)
  zone               String
  advancedZone       String
  intentClass        IntentClass     @default(PASS)
  intentConfidence   Float           @default(0)
  outcome            ShotOutcome     @default(MISSED)
  recovered          Boolean         @default(false)
  isAssist           Boolean         @default(false)
  classifiedAt       DateTime?
  classifiedBy       String?
  confidence         MetricConfidence
  externalId         String?
  permalink          String?
  rawActivityId      String?
  rawActivity        RawActivity?    @relation(fields: [rawActivityId], references: [id])
  acquiredVia        AcquisitionProvider?
  acquiredAt         DateTime?
  sourceId           String?
  metrics            PostMetrics?
  scores             PostScores?
  rippleEvents       RippleEvent[]
  recommendedPlayId  String?
  recommendedPlay    Play?           @relation(fields: [recommendedPlayId], references: [id])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([platform, publishedAt])
  @@index([employeeId, publishedAt])
  @@index([surfaceId, publishedAt])
  @@index([rawActivityId])
  @@index([surfaceId, externalId])
  @@index([sourceId])
  @@index([campaign])
  @@index([employeeId, intentClass])
}

model PostMetrics {
  id                    String @id @default(cuid())
  postId                String @unique
  post                  Post   @relation(fields: [postId], references: [id])
  views                 Int
  reach                 Int
  likes                 Int
  comments              Int
  replies               Int
  reposts               Int
  quotes                Int
  shares                Int
  clicks                Int
  profileVisits         Int
  signups               Int
  paidSubscriptions     Int
  consultingLeads       Int
  revenue               Int
  assistedConversions   Int
}

model PostScores {
  id           String @id @default(cuid())
  postId       String @unique
  post         Post   @relation(fields: [postId], references: [id])
  awareness    Float
  engagement   Float
  trust        Float
  clicks       Float
  signups      Float
  paid         Float
  consulting   Float
  revenue      Float
  assists      Float
  surfaceIQ    Float
  socialTS     Float
  assistRate   Float
  trustGravity Float
  humanHalo    Float
}

model RippleEvent {
  id         String           @id @default(cuid())
  rootPostId String
  rootPost   Post             @relation(fields: [rootPostId], references: [id])
  parentId   String?
  employeeId String?
  employee   Employee?        @relation(fields: [employeeId], references: [id])
  actor      String
  platform   Platform
  eventType  String
  occurredAt DateTime
  value      Int
  confidence MetricConfidence
}

model Metric {
  id                    String   @id @default(cuid())
  employeeId            String
  employee              Employee @relation(fields: [employeeId], references: [id])
  surfaceId             String
  surface               Surface  @relation(fields: [surfaceId], references: [id])
  platform              Platform
  timeWindow            String
  windowStart           DateTime
  windowEnd             DateTime?
  posts                 Int      @default(0)
  views                 Int      @default(0)
  reach                 Int      @default(0)
  likes                 Int      @default(0)
  comments              Int      @default(0)
  replies               Int      @default(0)
  reposts               Int      @default(0)
  quotes                Int      @default(0)
  shares                Int      @default(0)
  clicks                Int      @default(0)
  profileVisits         Int      @default(0)
  signups               Int      @default(0)
  paidSubscriptions     Int      @default(0)
  consultingLeads       Int      @default(0)
  revenue               Int      @default(0)
  assistedConversions   Int      @default(0)
  surfaceIQ             Float    @default(0)
  socialTS              Float    @default(0)
  assistRate            Float    @default(0)
  trustGravity          Float    @default(0)
  totalAttempts         Int      @default(0)
  threePtAttempts       Int      @default(0)
  midAttempts           Int      @default(0)
  paintAttempts         Int      @default(0)
  ftAttempts            Int      @default(0)
  ftMade                Int      @default(0)
  passes                Int      @default(0)
  turnovers             Int      @default(0)
  threePtMade           Int      @default(0)
  midMade               Int      @default(0)
  paintMade             Int      @default(0)
  threePtPct            Float    @default(0)
  midPct                Float    @default(0)
  paintPct              Float    @default(0)
  fgPct                 Float    @default(0)
  effectiveFgPct        Float    @default(0)
  trueShootingPct       Float    @default(0)
  pacePerWeek           Float    @default(0)
  brandTouchEvery       Float    @default(0)
  brandTouchPersonal    Float    @default(0)
  assistsCreated        Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([employeeId, timeWindow, windowStart])
  @@index([surfaceId, timeWindow, windowStart])
  @@unique([employeeId, surfaceId, timeWindow, windowStart])
}

model Play {
  id                        String       @id
  name                      String
  bestFor                   String
  bestPlatforms             Platform[]
  structure                 String
  whyItWorks                String
  historicalSignal          String
  recommendedNextExperiment String
  posts                     Post[]
  experiments               Experiment[]
}

model Experiment {
  id              String   @id @default(cuid())
  playId          String
  play            Play     @relation(fields: [playId], references: [id])
  ownerEmployeeId String
  owner           Employee @relation(fields: [ownerEmployeeId], references: [id])
  name            String
  hypothesis      String
  status          String
  metric          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Report {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  title     String
  period    String
  status    String
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DataSource {
  id          String           @id @default(cuid())
  name        String
  category    String
  readiness   SourceReadiness
  confidence  MetricConfidence
  description String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model AcquisitionRoute {
  id             String              @id @default(cuid())
  platform       Platform
  provider       AcquisitionProvider
  routeOrder     Int
  capability     String
  requiredEnv    String?
  confidence     MetricConfidence    @default(ESTIMATED)
  complianceNote String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([platform, provider, routeOrder])
  @@index([platform, routeOrder])
}

model AcquisitionJob {
  id            String               @id @default(cuid())
  surfaceId     String
  surface       Surface              @relation(fields: [surfaceId], references: [id])
  provider      AcquisitionProvider
  status        AcquisitionJobStatus @default(QUEUED)
  windowStart   DateTime
  windowEnd     DateTime
  attempts      Int                  @default(0)
  rawCount      Int                  @default(0)
  inserted      Int                  @default(0)
  updated       Int                  @default(0)
  skipped       Int                  @default(0)
  failureCode   String?
  failureReason String?
  rawActivities RawActivity[]
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([surfaceId, createdAt])
  @@index([provider, status])
}

model RawActivity {
  id          String              @id @default(cuid())
  surfaceId   String
  surface     Surface             @relation(fields: [surfaceId], references: [id])
  jobId       String?
  job         AcquisitionJob?     @relation(fields: [jobId], references: [id])
  provider    AcquisitionProvider
  externalId  String
  permalink   String?
  publishedAt DateTime
  text        String
  rawMetrics  Json                @default("{}")
  rawPayload  Json                @default("{}")
  citations   Json                @default("[]")
  basis       Json?
  confidence  MetricConfidence    @default(ESTIMATED)
  posts       Post[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([surfaceId, externalId])
  @@index([surfaceId, publishedAt])
  @@index([provider, publishedAt])
}

// Ingestion staging (raw pulls before normalization into Post / RawActivity)
model RawPost {
  id                 String   @id @default(cuid())
  platform           String
  nativeId           String
  entityType         String // company | employee | product
  entityId           String
  content            String   @db.Text
  contentType        String
  url                String?
  mediaUrl           String?
  postedAt           DateTime
  collectedAt        DateTime @default(now())
  rawReach           Int?
  rawLikes           Int?
  rawReplies         Int?
  rawReposts         Int?
  rawClicks          Int?
  rawOpens           Int?
  rawComments        Int?
  rawStars           Int?
  rawForks           Int?
  rawMetrics         Json?
  extractedUrls      String[] @default([])
  rawHash            String   @unique
  normalizedToPostId String?  @unique

  @@index([platform, entityId, postedAt])
}

model TrackedRedirect {
  id             String   @id @default(cuid())
  shortId        String   @unique
  postId         String?
  destinationUrl String
  clickCount     Int      @default(0)
  utmCampaign    String?
  utmMedium      String?
  utmContent     String?
  createdAt      DateTime @default(now())
}

model ConversionEvent {
  id          String   @id @default(cuid())
  redirectId  String?
  postId      String?
  entityType  String
  entityId    String
  eventType   String
  referrerUrl String?
  utmCampaign String?
  utmMedium   String?
  utmContent  String?
  userAgent   String?
  ipAddress   String?
  occurredAt  DateTime @default(now())

  @@index([entityType, entityId, eventType])
  @@index([occurredAt])
}

// Phase 4 — surface discovery (staging before Surface / acquisition jobs)
model DiscoveredSurface {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  surface         String
  label           String
  handle          String?
  url             String?
  status          String   @default("unknown")
  discoveryMethod String
  discoveredAt    DateTime @default(now())
  lastVerifiedAt  DateTime?
  confidenceScore Float    @default(0)
  evidence        String[] @default([])
  notes           String?
  searchQuery     String?
  searchRank      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, surface, handle])
  @@index([employeeId])
  @@index([surface])
  @@index([status])
}

model DiscoveryJob {
  id                String    @id @default(cuid())
  jobType           String
  status            String    @default("pending")
  employeeId        String?
  surface           String?
  surfacesFound     Int       @default(0)
  surfacesUpdated   Int       @default(0)
  errors            String[]  @default([])
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([status])
  @@index([employeeId])
}
